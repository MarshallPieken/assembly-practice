# ====================================================================
# Assembly Language Gitignore
# ====================================================================

# Object files (compiled but unlinked code)
*.o
*.obj

# Executables and Binaries
*.exe
*.out
*.com
*.bin
*.elf

# Debugger and Listing Files (Generated by assemblers like NASM/MASM)
*.lst
*.map
*.sym
*.pdb
*.ilk

# Temporary / Hex files
*.hex
*.tmp

# OS-specific overrides (Optional but recommended)
.DS_Store
Thumbs.db
